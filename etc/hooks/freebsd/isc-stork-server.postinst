#!/bin/sh

set -eu

pw group add stork-server || /bin/true
pw user add -n stork-server -c "Stork Server User" -g stork-server || /bin/true

# Ensure the authentication-methods directory exists and is writable by
# the stork-server user so that LDAP hook icons can be written there.
auth_methods_dir=/usr/local/share/stork/www/assets/authentication-methods
mkdir -p "${auth_methods_dir}"
chown stork-server "${auth_methods_dir}"
